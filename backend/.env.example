# LLM Configuration - Using Groq
GROQ_API_KEY=<your_groq_api_key_here>
GROQ_MODEL_NARRATIVE=llama-3.1-8b-instant
GROQ_MODEL_ORCHESTRATOR=groq/llama-3.3-70b-versatile
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

LLM_BACKEND=groq
LLM_USAGE_MODE=FULL
ENABLE_CREWAI_MANAGER=true
CREWAI_LLM_PROVIDER=litellm

# Commented out - not needed for Groq provider
# GEMINI_API_KEY=<your_gemini_api_key_here>
# GOOGLE_API_KEY=<your_google_api_key_here>
# GEMINI_MODEL=gemini-2.5-flash-lite
# VERTEX_PROJECT=<your_vertex_project_id_here>
# VERTEX_LOCATION=<your_vertex_location_here>

DATA_DIR=data
DATASET_DIR=dataset

# PostgreSQL Database Configuration
PG_USER=postgres
PG_PASSWORD=postgres
PG_PORT=5433
PG_HOST=localhost
PG_DB=jatayu

USE_PGVECTOR=true

# OTP Email Delivery (required for signup and login verification emails)
# Fill these with your SMTP provider details, then copy this file to .env.
# Example providers: Gmail SMTP, SendGrid SMTP relay, Mailtrap, AWS SES SMTP.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=<your_smtp_username>
SMTP_PASSWORD=<your_smtp_password>
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_USE_TLS=true

# Optional OTP tuning
OTP_LENGTH=6
OTP_EXPIRATION_MINUTES=10
OTP_HASH_SECRET=<set_a_random_secret_value>