# ═══════════════════════════════════════════════════════════════════════════
# Backend Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════

# ── Gemini LLM Configuration ──────────────────────────────────────────────
# Get API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_api_key_here

# Model options:
# - gemini-2.0-flash-exp (latest, fast, recommended)
# - gemini-1.5-flash (stable)
# - gemini-1.5-pro (higher quality, slower, more expensive)
# NOTE: gemini-2.5-flash does NOT exist - use 2.0-flash-exp
GEMINI_MODEL=gemini-2.0-flash-exp

# ──  LLM Usage Control (IMPORTANT for rate limiting) ─────────────────────
# Controls how aggressively LLM is used for narratives and explanations
# Options:
#   FULL     - Call LLM for all narratives (credit, fraud, compliance)
#   MINIMAL  - Only call LLM for REJECT/ESCALATE cases
#   FALLBACK - Never call LLM, use fallback text only
# Default: FULL
# RECOMMENDED for rate-limited scenarios: MINIMAL or FALLBACK
LLM_USAGE_MODE=FULL

# ── Data Directories ──────────────────────────────────────────────────────
DATA_DIR=data
DATASET_DIR=dataset

# ── Orchestration Mode ────────────────────────────────────────────────────
# If GEMINI_API_KEY is set: CrewAI mode (manager agent orchestrates)
# If not set: Direct mode (sequential pipeline)
# CrewAI mode uses more LLM calls - use Direct mode to save quota

# ── Optional: Ollama for Fraud Agent ──────────────────────────────────────
# Fraud agent can optionally use Ollama for enhanced explanations
# If Ollama not available, it falls back gracefully
# Install: https://ollama.ai
# Then: ollama pull qwen2.5:0.5b
OLLAMA_ENABLED=false
